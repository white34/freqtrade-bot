# Copy to .env and fill in. .env is gitignored — never commit secrets.
#
# Telegram alerting (strongly recommended — the old bot died silently for 3 weeks):
#   1. Message @BotFather on Telegram -> /newbot -> copy the token
#   2. Message your new bot once, then visit
#      https://api.telegram.org/bot<TOKEN>/getUpdates  to find your chat id
#   3. Fill both values below and set ENABLED to true
FREQTRADE__TELEGRAM__ENABLED=false
FREQTRADE__TELEGRAM__TOKEN=
FREQTRADE__TELEGRAM__CHAT_ID=

# Exchange API keys stay empty for dry-run. For live (much later):
# FREQTRADE__EXCHANGE__KEY=
# FREQTRADE__EXCHANGE__SECRET=
